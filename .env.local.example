# ============================================
# ROTA FITWEAR - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha os valores

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# STRIPE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# MERCADO PAGO
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-...
MP_ACCESS_TOKEN=TEST-...
MP_WEBHOOK_SECRET=your-webhook-secret

# CLOUDINARY
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# REDIS (Upstash)
REDIS_URL=redis://...
REDIS_TOKEN=your-token

# ANTHROPIC AI (Assistente Virtual)
ANTHROPIC_API_KEY=sk-ant-...

# RESEND (Email)
RESEND_API_KEY=re_...
EMAIL_FROM=contato@rotafitwear.com.br

# GOOGLE ANALYTICS
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...

# META PIXEL
NEXT_PUBLIC_META_PIXEL_ID=...

# TIKTOK PIXEL
NEXT_PUBLIC_TIKTOK_PIXEL_ID=...

# SITE
NEXT_PUBLIC_SITE_URL=https://rotafitwear.com.br
NEXT_PUBLIC_SITE_NAME=Rota Fitwear

# WHATSAPP
WHATSAPP_API_TOKEN=your-token
WHATSAPP_PHONE_ID=your-phone-id

# NEXTAUTH
NEXTAUTH_SECRET=your-secret-key-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
